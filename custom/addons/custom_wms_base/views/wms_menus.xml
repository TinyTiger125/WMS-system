<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_custom_wms_root"
        name="跨境进销存"
        sequence="1"
        groups="base.group_system,custom_wms_base.group_wms_boss,custom_wms_base.group_wms_warehouse_ops,custom_wms_base.group_wms_sales_ops,custom_wms_base.group_wms_service_ops"/>

    <record id="action_custom_wms_product_master" model="ir.actions.act_window">
        <field name="name">商品档案</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="view_id" ref="custom_wms_base.view_product_template_tree_wms_master"/>
        <field name="search_view_id" ref="custom_wms_base.view_product_template_search_wms_master"/>
        <field name="context">{'default_type': 'consu', 'default_is_storable': True, 'search_default_has_barcode': 1}</field>
        <field name="help" type="html">
            <p>先完成商品主数据，再开始采购和销售流程。</p>
        </field>
    </record>

    <record id="action_custom_wms_product_create" model="ir.actions.act_window">
        <field name="name">商品登记（新增）</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="product.product_template_only_form_view"/>
        <field name="context">{'default_type': 'consu', 'default_is_storable': True, 'default_sale_ok': True, 'default_purchase_ok': True}</field>
        <field name="help" type="html">
            <p>新手建议先登记 1 个测试商品，验证后再批量导入。</p>
        </field>
    </record>

    <record id="action_custom_wms_purchase_flow" model="ir.actions.act_window">
        <field name="name">采购下单</field>
        <field name="res_model">purchase.order</field>
        <field name="view_id" ref="custom_wms_base.view_purchase_order_tree_wms_safe"/>
        <field name="view_mode">list,form,kanban,pivot,graph,activity</field>
        <field name="domain">[('state', 'in', ('draft', 'sent', 'to approve', 'purchase', 'done'))]</field>
        <field name="help" type="html">
            <p>暂无采购单。建议先从“商品与主数据”完成商品登记，再创建采购单。</p>
        </field>
    </record>

    <record id="action_custom_wms_receipts_flow" model="ir.actions.act_window">
        <field name="name">采购入库</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,kanban,form,calendar,activity</field>
        <field name="domain">[('picking_type_code', '=', 'incoming')]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p>暂无入库单。采购单确认后会自动生成入库单。</p>
        </field>
    </record>

    <record id="action_custom_wms_sales_flow" model="ir.actions.act_window">
        <field name="name">销售订单</field>
        <field name="res_model">sale.order</field>
        <field name="view_id" ref="custom_wms_base.view_sale_order_tree_wms_safe"/>
        <field name="view_mode">list,kanban,form,pivot,graph,activity</field>
        <field name="domain">[('state', 'in', ('draft', 'sent', 'sale', 'done'))]</field>
        <field name="help" type="html">
            <p>暂无销售单。可先从“商品档案”确认可售商品，再开始销售下单。</p>
        </field>
    </record>

    <record id="action_custom_wms_pricelist" model="ir.actions.act_window">
        <field name="name">销售价格表</field>
        <field name="res_model">product.pricelist</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>用于日常维护销售价格规则，销售单“价格表”字段将直接引用这里的数据。</p>
        </field>
    </record>

    <record id="action_custom_wms_deliveries_flow" model="ir.actions.act_window">
        <field name="name">销售出库</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,kanban,form,calendar,activity</field>
        <field name="domain">[('picking_type_code', '=', 'outgoing')]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p>暂无出库单。销售订单确认后会自动生成出库单。</p>
        </field>
    </record>

    <record id="action_custom_wms_todo_purchase_confirm" model="ir.actions.act_window">
        <field name="name">待采购确认</field>
        <field name="res_model">purchase.order</field>
        <field name="view_id" ref="custom_wms_base.view_purchase_order_tree_wms_safe"/>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ('draft', 'sent', 'to approve'))]</field>
        <field name="help" type="html">
            <p>这里是老板待处理的采购确认任务。</p>
        </field>
    </record>

    <record id="action_custom_wms_todo_receipt" model="ir.actions.act_window">
        <field name="name">待采购入库</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('picking_type_code', '=', 'incoming'), ('state', 'not in', ('done', 'cancel'))]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p>这里是库管待处理的采购入库任务。</p>
        </field>
    </record>

    <record id="action_custom_wms_todo_delivery" model="ir.actions.act_window">
        <field name="name">待销售出库</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="domain">[('picking_type_code', '=', 'outgoing'), ('state', 'not in', ('done', 'cancel'))]</field>
        <field name="context">{'create': False}</field>
        <field name="help" type="html">
            <p>这里是库管待处理的销售出库任务。</p>
        </field>
    </record>

    <record id="action_custom_wms_todo_low_stock" model="ir.actions.act_window">
        <field name="name">低库存预警</field>
        <field name="res_model">custom.wms.stock.exception</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status', '=', 'low')]</field>
        <field name="help" type="html">
            <p>这里是需要优先补货的低库存商品。</p>
        </field>
    </record>

