<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_custom_wms_customer_contract_tree" model="ir.ui.view">
        <field name="name">custom.wms.customer.contract.tree</field>
        <field name="model">custom.wms.customer.contract</field>
        <field name="arch" type="xml">
            <list string="框架合同">
                <field name="active" column_invisible="True"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="line_count"/>
            </list>
        </field>
    </record>

    <record id="view_custom_wms_customer_contract_form" model="ir.ui.view">
        <field name="name">custom.wms.customer.contract.form</field>
        <field name="model">custom.wms.customer.contract</field>
        <field name="arch" type="xml">
            <form string="框架合同">
                <header>
                    <button name="action_view_lines" type="object" string="查看合同商品" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="user_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="可记录价格约定、执行规则等。"/>
                    </group>
                    <group string="合同商品">
                        <field name="line_ids" context="{'default_contract_id': id}">
                            <list editable="bottom">
                                <field name="active"/>
                                <field name="product_tmpl_id"/>
                                <field name="price_unit"/>
                                <field name="min_order_qty"/>
                                <field name="max_order_qty"/>
                                <field name="ordered_qty" readonly="1"/>
                                <field name="remaining_qty" readonly="1"/>
                                <field name="available_qty" readonly="1"/>
                                <field name="orderable_qty" readonly="1"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_custom_wms_customer_contract_line_tree" model="ir.ui.view">
        <field name="name">custom.wms.customer.contract.line.tree</field>
        <field name="model">custom.wms.customer.contract.line</field>
        <field name="arch" type="xml">
            <list string="合同商品库存">
                <header>
                    <button name="action_open_order_wizard" type="object" string="按库存下单" class="btn-primary"/>
                </header>
                <field name="active" column_invisible="True"/>
                <field name="contract_id"/>
                <field name="product_tmpl_id"/>
                <field name="price_unit"/>
                <field name="available_qty"/>
                <field name="ordered_qty"/>
                <field name="remaining_qty"/>
                <field name="orderable_qty"/>
            </list>
        </field>
    </record>

    <record id="view_custom_wms_customer_contract_line_form" model="ir.ui.view">
        <field name="name">custom.wms.customer.contract.line.form</field>
        <field name="model">custom.wms.customer.contract.line</field>
        <field name="arch" type="xml">
            <form string="合同商品">
                <header>
                    <button name="action_open_order_wizard" type="object" string="按库存下单" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="contract_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="product_tmpl_id"/>
                        </group>
                        <group>
                            <field name="price_unit"/>
                            <field name="min_order_qty"/>
                            <field name="max_order_qty"/>
                            <field name="ordered_qty" readonly="1"/>
                            <field name="remaining_qty" readonly="1"/>
                            <field name="available_qty" readonly="1"/>
                            <field name="orderable_qty" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_custom_wms_customer_order_wizard_form" model="ir.ui.view">
        <field name="name">custom.wms.customer.order.wizard.form</field>
        <field name="model">custom.wms.customer.order.wizard</field>
        <field name="arch" type="xml">
            <form string="客户下单">
                <group>
                    <group>
                        <field name="contract_line_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="product_tmpl_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="price_unit" readonly="1"/>
                        <field name="available_qty" readonly="1"/>
                        <field name="orderable_qty" readonly="1"/>
                        <field name="order_qty"/>
                    </group>
                </group>
                <footer>
                    <button name="action_create_sale_order" type="object" string="确认下单" class="btn-primary"/>
                    <button special="cancel" string="取消"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_custom_wms_customer_contract" model="ir.actions.act_window">
        <field name="name">框架合同管理</field>
        <field name="res_model">custom.wms.customer.contract</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_custom_wms_customer_contract_tree"/>
    </record>

    <record id="action_custom_wms_customer_contract_line" model="ir.actions.act_window">
        <field name="name">合同库存</field>
        <field name="res_model">custom.wms.customer.contract.line</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_custom_wms_customer_contract_line_tree"/>
        <field name="context">{'create': False}</field>
    </record>

    <record id="action_custom_wms_customer_my_orders" model="ir.actions.act_window">
        <field name="name">我的订单</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="custom_wms_base.view_sale_order_tree_wms_safe"/>
        <field name="context">{'create': False}</field>
        <field name="domain">[('wms_customer_contract_id', '!=', False)]</field>
    </record>
</odoo>
