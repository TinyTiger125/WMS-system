<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_custom_wms_dashboard_boss" model="ir.actions.act_window">
        <field name="name">老板工作台</field>
        <field name="res_model">custom.wms.daily.kpi</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="help" type="html">
            <p>先看经营日报，再下钻到库存预警和审计日志。</p>
        </field>
    </record>

    <record id="action_custom_wms_dashboard_warehouse" model="ir.actions.act_window">
        <field name="name">仓库工作台</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', 'not in', ('done', 'cancel')), ('picking_type_code', 'in', ('incoming', 'outgoing'))]</field>
        <field name="context">{'search_default_group_by_picking_type': 1}</field>
        <field name="help" type="html">
            <p>优先处理待办入库/出库，避免单据积压。</p>
        </field>
    </record>

    <record id="action_custom_wms_dashboard_sales" model="ir.actions.act_window">
        <field name="name">销售工作台</field>
        <field name="res_model">sale.order</field>
        <field name="view_id" ref="custom_wms_base.view_sale_order_tree_wms_safe"/>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('state', 'in', ('draft', 'sent', 'sale'))]</field>
        <field name="help" type="html">
            <p>优先处理草稿和待确认订单，降低履约延迟。</p>
        </field>
    </record>

    <record id="action_custom_wms_boss_procurement_view" model="ir.actions.act_window">
        <field name="name">老板视角：采购工作台</field>
        <field name="res_model">purchase.order</field>
        <field name="view_id" ref="custom_wms_base.view_purchase_order_tree_wms_safe"/>
        <field name="view_mode">list,kanban,form,pivot</field>
        <field name="domain">[('state', 'in', ('draft', 'sent', 'to approve', 'purchase'))]</field>
        <field name="help" type="html">
            <p>老板采购视角：优先处理待确认采购和在途采购。</p>
        </field>
    </record>

    <record id="action_custom_wms_boss_sales_view" model="ir.actions.act_window">
        <field name="name">老板视角：销售工作台</field>
        <field name="res_model">sale.order</field>
        <field name="view_id" ref="custom_wms_base.view_sale_order_tree_wms_safe"/>
        <field name="view_mode">list,kanban,form,pivot</field>
        <field name="domain">[('state', 'in', ('draft', 'sent', 'sale'))]</field>
        <field name="help" type="html">
            <p>老板销售视角：优先处理待确认销售和待发货订单。</p>
        </field>
    </record>

    <menuitem id="menu_custom_wms_dashboard_boss"
        name="老板工作台"
        parent="custom_wms_base.menu_custom_wms_workspace_root"
        action="custom_wms_base.action_custom_wms_open_boss_dashboard"
        sequence="10"
        groups="base.group_system,custom_wms_base.group_wms_boss"/>

    <menuitem id="menu_custom_wms_dashboard_warehouse"
        name="仓库工作台"
        parent="custom_wms_base.menu_custom_wms_workspace_root"
        action="custom_wms_base.action_custom_wms_open_warehouse_dashboard"
        sequence="20"
        groups="base.group_system,custom_wms_base.group_wms_boss,custom_wms_base.group_wms_warehouse_ops"/>

    <menuitem id="menu_custom_wms_dashboard_service"
        name="客服工作台"
        parent="custom_wms_base.menu_custom_wms_workspace_root"
        action="custom_wms_base.action_custom_wms_open_service_dashboard"
        sequence="22"
        groups="base.group_system,custom_wms_base.group_wms_boss,custom_wms_base.group_wms_service_ops"/>

    <menuitem id="menu_custom_wms_boss_procurement_view"
        name="老板视角：采购"
        parent="custom_wms_base.menu_custom_wms_workspace_root"
        action="action_custom_wms_boss_procurement_view"
        sequence="14"
        groups="base.group_system,custom_wms_base.group_wms_boss"/>

    <menuitem id="menu_custom_wms_boss_sales_view"
        name="老板视角：销售"
        parent="custom_wms_base.menu_custom_wms_workspace_root"
        action="action_custom_wms_boss_sales_view"
        sequence="15"
        groups="base.group_system,custom_wms_base.group_wms_boss"/>

    <menuitem id="menu_custom_wms_dashboard_sales"
        name="销售工作台"
        parent="custom_wms_base.menu_custom_wms_workspace_root"
        action="action_custom_wms_dashboard_sales"
        sequence="30"
        groups="base.group_system,custom_wms_base.group_wms_boss,custom_wms_base.group_wms_sales_ops"/>
</odoo>
