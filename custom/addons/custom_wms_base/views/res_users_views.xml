<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_list_wms_quick_create_button" model="ir.ui.view">
        <field name="name">res.users.list.wms.quick.create.button</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="%(custom_wms_base.action_custom_wms_user_quick_create)d"
                        type="action"
                        string="快速创建账号"
                        class="btn-primary"/>
                </header>
            </xpath>
        </field>
    </record>

    <record id="view_users_form_wms_role_panel" model="ir.ui.view">
        <field name="name">res.users.form.wms.role.panel</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(custom_wms_base.action_custom_wms_user_quick_create)d"
                    type="action"
                    string="快速创建账号"
                    class="btn-secondary"
                    groups="base.group_system"/>
            </xpath>
            <xpath expr="//page[@name='access_rights']" position="inside">
                <group string="WMS 统一权限中心（账号/角色/功能）" groups="base.group_system">
                    <group>
                        <label for="active"/>
                        <div>
                            <field name="active"/>
                        </div>
                    </group>
                    <group>
                        <div class="o_form_label text-muted">
                            建议先勾角色，再按需要微调功能开关。
                        </div>
                    </group>
                    <group string="角色管理">
                        <field name="wms_role_boss"/>
                        <field name="wms_role_warehouse"/>
                        <field name="wms_role_sales"/>
                        <field name="wms_role_service"/>
                    </group>
                    <group string="功能管理（可自由调配）">
                        <field name="wms_feature_workspace"/>
                        <field name="wms_feature_master_data"/>
                        <field name="wms_feature_purchase_order"/>
                        <field name="wms_feature_purchase_receipt"/>
                        <field name="wms_feature_sales_order"/>
                        <field name="wms_feature_sales_delivery"/>
                        <field name="wms_feature_inventory"/>
                        <field name="wms_feature_exception_center"/>
                        <field name="wms_feature_reporting"/>
                        <field name="wms_feature_service_ticket"/>
                    </group>
                    <group string="权限结果预览（自动计算）">
                        <field name="wms_can_purchase_order" readonly="1"/>
                        <field name="wms_can_purchase_receipt" readonly="1"/>
                        <field name="wms_can_sales_order" readonly="1"/>
                        <field name="wms_can_sales_delivery" readonly="1"/>
                        <field name="wms_can_reporting" readonly="1"/>
                    </group>
                    <div class="o_form_label text-muted">
                        说明：角色用于快速套模板，功能开关用于精细化控制。
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
