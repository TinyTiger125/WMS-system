<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_custom_wms_stock_exception_refresh" model="ir.cron">
        <field name="name">WMS - Refresh Stock Exceptions</field>
        <field name="model_id" ref="model_custom_wms_stock_exception"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_exceptions()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_custom_wms_daily_kpi" model="ir.cron">
        <field name="name">WMS - Generate Daily KPI</field>
        <field name="model_id" ref="model_custom_wms_daily_kpi"/>
        <field name="state">code</field>
        <field name="code">model._cron_generate_daily_kpi()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
