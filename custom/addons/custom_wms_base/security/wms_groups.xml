        <record model="res.groups.privilege" id="res_groups_privilege_custom_wms">
            <field name="name">Custom WMS</field>
            <field name="category_id" ref="base.module_category_supply_chain"/>
        </record>

        <record id="group_wms_feature_workspace" model="res.groups">
            <field name="name">功能/工作台与待办</field>
            <field name="sequence">1</field>
            <field name="privilege_id" ref="custom_wms_base.res_groups_privilege_custom_wms"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_wms_feature_master_data" model="res.groups">
            <field name="name">功能/商品与主数据</field>
            <field name="sequence">2</field>
