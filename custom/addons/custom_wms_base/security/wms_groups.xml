<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="res.groups.privilege" id="res_groups_privilege_custom_wms">
            <field name="name">Custom WMS</field>
            <field name="category_id" ref="base.module_category_supply_chain"/>
        </record>

        <record id="group_wms_sales_ops" model="res.groups">
            <field name="name">Sales Ops</field>
            <field name="sequence">10</field>
            <field name="privilege_id" ref="custom_wms_base.res_groups_privilege_custom_wms"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="group_wms_warehouse_ops" model="res.groups">
            <field name="name">Warehouse Ops</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="custom_wms_base.res_groups_privilege_custom_wms"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('stock.group_stock_user'))]"/>
        </record>

        <record id="group_wms_service_ops" model="res.groups">
            <field name="name">Service Ops</field>
            <field name="sequence">25</field>
            <field name="privilege_id" ref="custom_wms_base.res_groups_privilege_custom_wms"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_wms_boss" model="res.groups">
            <field name="name">Boss</field>
            <field name="sequence">30</field>
            <field name="privilege_id" ref="custom_wms_base.res_groups_privilege_custom_wms"/>
            <field name="implied_ids" eval="[
                (4, ref('base.group_user')),
                (4, ref('sales_team.group_sale_manager')),
                (4, ref('purchase.group_purchase_manager')),
                (4, ref('stock.group_stock_manager')),
                (4, ref('account.group_account_manager'))
            ]"/>
        </record>
    </data>
</odoo>
